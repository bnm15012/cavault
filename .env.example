# ── MySQL database ────────────────────────────────────────────────────────────
# Use TiDB Cloud (free): https://tidbcloud.com
MYSQL_HOST=gateway01.eu-central-1.prod.aws.tidbcloud.com
MYSQL_PORT=4000
MYSQL_DATABASE=clientfilehub
MYSQL_USER=your-db-user
MYSQL_PASSWORD=your-db-password

# ── Cloudflare R2 — file storage (server-side only, never expose to browser) ──
# Get from: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=cavault
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── SMTP — for OTP and confirmation emails ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=CA Vault <your@gmail.com>

# ── Razorpay — payment processing (server-side only) ─────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── App URL — used in email confirmation links ────────────────────────────────
VITE_APP_URL=https://your-production-domain.com

# ── Skip email confirmation on signup (local dev only) ────────────────────────
SKIP_EMAIL_CONFIRMATION=false
VITE_SKIP_EMAIL_CONFIRMATION=false
