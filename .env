# ─── LOCAL DEVELOPMENT ENVIRONMENT ───────────────────────────────────────────
# Disable SSL cert verification locally — Cloudflare R2 certs fail on some macOS Node versions
NODE_TLS_REJECT_UNAUTHORIZED="0"
# The canonical URL for email confirmation links — prevents Lovable preview URLs
# ending up in confirmation emails when testing via the Lovable editor.
VITE_APP_URL="http://localhost:8080"

# Set to "true" to skip email confirmation on signup (local dev only).
# In production leave this unset or "false".
VITE_SKIP_EMAIL_CONFIRMATION="true"
SKIP_EMAIL_CONFIRMATION="true"
# This file is gitignored (*.local). Fill in your local values.

